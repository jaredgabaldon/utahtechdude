---
import BaseLayout from "../layouts/BaseLayout.astro";
import { locationPages, servicePages } from "../data/services";

const services = [
  "Smart TV setup and streaming app installation",
  "Smart watch setup, syncing, and troubleshooting",
  "Alexa, Echo, and voice assistant setup",
  "Apple Pay, digital wallet, and account support",
  "Wi-Fi setup, reconnecting, and home network help",
  "Password management, resets, and account recovery guidance",
  "App downloads, sign-ins, and device onboarding",
  "Smart lights, switches, fans, and other connected devices",
  "Printer setup and wireless printing help",
  "Phone, tablet, and iPad setup",
  "Photo backup and cloud sync setup",
  "Mesh Wi-Fi and router setup",
  "Parental controls and family device setup",
  "Home office and video call setup",
  "Scam cleanup and basic digital safety guidance",
  "Ongoing remote or in-home tech support"
];

const serviceCategories = [
  {
    title: "Setup Services",
    description:
      "New-device onboarding for TVs, phones, tablets, smart watches, printers, streaming devices, and smart home gear.",
    items: [
      "Phone and tablet setup",
      "Printer and wireless printing setup",
      "Streaming device and smart TV setup",
      "Smart watch pairing and syncing"
    ]
  },
  {
    title: "Troubleshooting Services",
    description:
      "Practical help when devices stop talking to each other, accounts get locked, or home tech starts acting up.",
    items: [
      "Wi-Fi and router troubleshooting",
      "Password management, resets, and account recovery",
      "App sign-in and syncing issues",
      "Smart device reconnection help"
    ]
  },
  {
    title: "Ongoing Support",
    description:
      "Services that create repeat business and make life easier for households that want a go-to tech helper.",
    items: [
      "Senior-friendly technology coaching",
      "Monthly tech care support",
      "Seasonal tech tune-ups",
      "Move-in and reconnect service"
    ]
  }
];

const highlights = [
  {
    title: "Friendly in-home help",
    description:
      "Clear, patient setup support for the tech that should make life easier, not more frustrating."
  },
  {
    title: "One call for many devices",
    description:
      "From TVs and phones to smart home gear, get one go-to local expert to help connect it all."
  },
  {
    title: "Built for real households",
    description:
      "Simple, practical help for families, older adults, busy professionals, and anyone tired of confusing setup screens."
  }
];

const process = [
  "Tell me what device or setup issue you need help with.",
  "We get your accounts, apps, Wi-Fi, and devices working together.",
  "You get a simple walkthrough so you feel confident using everything."
];

const faqItems = [
  {
    question: "Do you help with smart TV and streaming setup?",
    answer:
      "Yes. Utah Tech Dude helps connect smart TVs, install streaming apps, sign into accounts, and make sure remotes and Wi-Fi are working correctly."
  },
  {
    question: "Can you help with Wi-Fi, passwords, and account recovery?",
    answer:
      "Yes. Support includes reconnecting devices to Wi-Fi, helping with password resets, and walking through common account access problems."
  },
  {
    question: "Do you set up smart home devices like lights and switches?",
    answer:
      "Yes. Smart lights, switches, fans, voice assistants, and other connected devices can be set up and linked together for simpler everyday use."
  }
];

const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    name: "Utah Tech Dude",
    url: "https://utahtechdude.com",
    email: "help@utahtechdude.com",
    areaServed: "Utah",
    description:
      "Home tech setup help in Utah for smart TVs, smart watches, Alexa, Apple Pay, Wi-Fi, password recovery, app setup, printers, backups, and smart home devices."
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqItems.map((item) => ({
      "@type": "Question",
      name: item.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: item.answer
      }
    }))
  }
];
---

<BaseLayout
  title="Home Tech Support in Utah | Smart Home Setup, Wi-Fi Help, and Device Support"
  description="Utah Tech Dude provides home tech support in Utah for smart home setup, Wi-Fi help, smart TVs, Alexa, password recovery, app setup, printers, backups, and device support."
  structuredData={structuredData}
>
  <main class="page-shell">
    <section class="hero">
      <div class="hero__copy">
        <p class="eyebrow">Utah Tech Dude</p>
        <h1>Home tech support in Utah that feels simple, local, and stress-free.</h1>
        <p class="hero__lede">
          I help people across Utah get everyday tech working at home, from smart TVs
          and Wi-Fi to Apple Pay, Alexa, password recovery, apps, printers, backups,
          and connected devices like lights, switches, and fans.
        </p>
        <div class="hero__actions">
          <a class="button button--primary" href="/contact/">Book Help</a>
          <a class="button button--secondary" href="/services/">See Services</a>
        </div>
      </div>

      <aside class="hero__card">
        <p class="hero__card-label">Popular requests</p>
        <ul>
          <li>Streaming setup for new smart TVs</li>
          <li>Recovering logins and passwords</li>
          <li>Fixing Wi-Fi and reconnecting devices</li>
          <li>Setting up Alexa and smart home controls</li>
        </ul>
      </aside>
    </section>

    <section class="panel panel--warm" id="services">
      <div class="section-heading">
        <p class="eyebrow">Services</p>
        <h2>Utah home tech support for the devices people use every day</h2>
      </div>
      <div class="service-grid">
        {services.map((service) => (
          <article class="service-card">
            <span class="service-card__dot" aria-hidden="true"></span>
            <p>{service}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="split-section">
      <div class="section-heading">
        <p class="eyebrow">Offerings</p>
        <h2>Three easy ways to explain what you do</h2>
      </div>
      <div class="highlight-grid">
        {serviceCategories.map((category) => (
          <article class="highlight-card">
            <h3>{category.title}</h3>
            <p>{category.description}</p>
            <p>{category.items.join(" • ")}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="split-section">
      <div class="section-heading">
        <p class="eyebrow">Service Pages</p>
        <h2>Search-focused pages for the most common tech help needs</h2>
      </div>
      <div class="highlight-grid">
        {servicePages.map((service) => (
          <article class="highlight-card">
            <h3>
              <a href={`/services/${service.slug}/`}>{service.shortTitle}</a>
            </h3>
            <p>{service.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="split-section">
      <div class="section-heading">
        <p class="eyebrow">Location Pages</p>
        <h2>Local landing pages for the Utah cities you want to reach</h2>
      </div>
      <div class="highlight-grid">
        {locationPages.map((location) => (
          <article class="highlight-card">
            <h3>
              <a href={`/locations/${location.slug}/`}>{location.city}</a>
            </h3>
            <p>{location.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="split-section">
      <div class="section-heading">
        <p class="eyebrow">Why People Call</p>
        <h2>Tech support without the confusing jargon</h2>
      </div>
      <div class="highlight-grid">
        {highlights.map((item) => (
          <article class="highlight-card">
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="panel panel--dark">
      <div class="section-heading section-heading--light">
        <p class="eyebrow">How It Works</p>
        <h2>Fast help from setup to confidence</h2>
      </div>
      <div class="process-list">
        {process.map((step, index) => (
          <article class="process-card">
            <p class="process-card__number">0{index + 1}</p>
            <p>{step}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="panel panel--warm">
      <div class="section-heading">
        <p class="eyebrow">Planning Pages</p>
        <h2>Pricing, FAQ, and contact pages that support conversions</h2>
      </div>
      <div class="highlight-grid">
        <article class="highlight-card">
          <h3><a href="/pricing/">Pricing</a></h3>
          <p>Simple starting packages help people understand the difference between setup, smart home work, and general tech help.</p>
        </article>
        <article class="highlight-card">
          <h3><a href="/faq/">FAQ</a></h3>
          <p>Answering common questions adds trust, helps with long-tail search intent, and supports FAQ schema.</p>
        </article>
        <article class="highlight-card">
          <h3><a href="/contact/">Contact</a></h3>
          <p>An email-first contact page keeps your personal phone number private while still giving customers a clear next step.</p>
        </article>
      </div>
    </section>

    <section class="split-section">
      <div class="section-heading">
        <p class="eyebrow">FAQ</p>
        <h2>Questions people ask before booking home tech help</h2>
      </div>
      <div class="highlight-grid">
        {faqItems.map((item) => (
          <article class="highlight-card">
            <h3>{item.question}</h3>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="contact" id="contact">
      <div class="contact__copy">
        <p class="eyebrow">Get Started</p>
        <h2>Need help setting up something at home?</h2>
        <p>
          Reach out for Utah home tech help with smart devices, account access,
          streaming, wireless setup, backups, and everyday troubleshooting.
        </p>
      </div>
      <div class="contact__card">
        <p class="contact__label">Contact by email</p>
        <a href="mailto:help@utahtechdude.com">help@utahtechdude.com</a>
        <p>Serving home tech customers across Utah.</p>
      </div>
    </section>
  </main>
</BaseLayout>
